# Supabase
# Get these from Supabase Dashboard > Project Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App config
VITE_APP_NAME=DeskFlow
VITE_APP_URL=http://localhost:5174

# Optional: Resend booking email notifications.
# Only needed if you deploy supabase/functions/send-booking-email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Optional: server-side demo login for api/demo-login.
# Set DEMO_EMAIL and DEMO_PASSWORD as Vercel environment variables so the
# password is not exposed in the frontend bundle.
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=your-password
